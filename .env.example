# ============================================
# StudyBuddyAI 环境变量配置
# 复制为 .env 后填入实际值
# ============================================

# --- 火山引擎账号（V4 签名 OpenAPI 认证） ---
VOLC_ACCESS_KEY=your_access_key_here
VOLC_SECRET_KEY=your_secret_key_here
VOLC_REGION=cn-north-1

# --- RTC 实时音视频 ---
VOLC_RTC_APP_ID=your_rtc_app_id
VOLC_RTC_APP_KEY=your_rtc_app_key
# VOLC_RTC_API_HOST=rtc.volcengineapi.com

# --- ASR 语音识别 ---
VOLC_ASR_APP_ID=your_asr_app_id

# --- LLM 大语言模型（豆包 Seed 2.0 Lite） ---
VOLC_LLM_ENDPOINT_ID=your_llm_endpoint_id

# --- TTS 语音合成 ---
VOLC_TTS_APP_ID=your_tts_app_id
VOLC_TTS_TOKEN=your_tts_token
# VOLC_TTS_VOICE=BV700_streaming

# --- 服务配置 ---
HOST=0.0.0.0
PORT=8000
DEBUG=true
